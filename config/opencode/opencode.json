{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ucl-arc-qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "UCL ARC Qwen",
      "options": {
        "baseURL": "https://inf01.arc-llm.condenser.arc.ucl.ac.uk/v1",
        "apiKey": "{env:UCL_ARC_API_KEY}"
      },
      "models": {
        "Qwen": {
          "name": "UCL/Qwen/Qwen3.6-35B-A3B-FP8"
        }
      }
    },
    "ucl-arc-qwen-coder": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "UCL ARC Qwen-Coder",
      "options": {
        "baseURL": "https://inf03.arc-llm.condenser.arc.ucl.ac.uk/v1",
        "apiKey": "{env:UCL_ARC_API_KEY}"
      },
      "models": {
        "Qwen-Coder": {
          "name": "UCL/Qwen3-Coder-30B-A3B-Instruct-FP8"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:1.7b": {
          "name": "qwen3"
        }
      }
    }
  },
  "lsp": {
      "ruff": {
          "command": ["ruff", "server"],
          "extensions": [".py"]
      },
      "ty": {
          "command": ["ty", "server"],
          "extensions": [".py"]
      },
      "pyright": {
          "disabled": true
      }
  }
}
